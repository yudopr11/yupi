# Database Configuration
# Format: postgresql://username:password@host:port/database_name
# Example for local development:
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/yupi_db

# Database Connection Pool (optional — defaults shown)
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800

# JWT Authentication Settings
# SECRET_KEY: Use a strong random string, at least 32 characters
# ALGORITHM: JWT encoding algorithm (HS256 recommended)
# ACCESS_TOKEN_EXPIRE_MINUTES: Token expiration time in minutes
# REFRESH_TOKEN_EXPIRE_DAYS: Number of days before refresh token expires
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES: Expiration time for password reset tokens
SECRET_KEY=your-super-secret-key-that-should-be-very-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# Default Superuser Credentials
# These credentials will be used to create the first superuser
# Make sure to change these in production
SUPERUSER_USERNAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=admin123

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# MiMo LLM Settings (for AI Chat / YuChat)
# Defaults can be overridden per-user via chat settings API
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5

# RustFS / S3-compatible Storage
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=your-rustfs-access-key
RUSTFS_SECRET_KEY=your-rustfs-secret-key
RUSTFS_BUCKET=yupi-uploads
RUSTFS_REGION=us-east-1

# Email Configuration for Password Reset
# For Gmail, use App Password instead of account password
# Create App Password: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
# MAIL_PORT=587
# MAIL_SERVER=smtp.gmail.com

# Ngakak Settings
# Set to True if behind a reverse proxy that sets X-Forwarded-For
# NGAKAK_TRUST_X_FORWARDED_FOR=False

# MCP Settings
# Enable DNS rebinding protection for MCP server (recommended for production)
# MCP_DNS_REBINDING_PROTECTION=False

# API Information
# These values are used in the API documentation
API_TITLE=yupi - yudopr API
API_DESCRIPTION=API for many yudopr webapp projects
API_VERSION=1.0.0

# CORS Settings (Optional)
# Comma-separated list of allowed origins
# Use "*" to allow all origins (not recommended for production)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_METHODS=["GET","POST","PUT","DELETE"]
CORS_HEADERS=["*"]
CORS_CREDENTIALS=True
CORS_MAX_AGE=600

# Cookie Settings
# COOKIE_SECURE: Set to False for local development (HTTP), True for production (HTTPS)
# WARNING: Setting True on HTTP will break refresh token — browser silently drops Secure cookies on non-HTTPS
COOKIE_SECURE=False
